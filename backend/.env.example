# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database (TiDB Cloud) ────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://root:password@localhost:4000/velifa

# ─── Redis (Upstash ou local) ─────────────────────────────────────────────────
# Local dev : redis://localhost:6379
# Upstash   : rediss://default:TOKEN@HOST.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── Google PageSpeed API ─────────────────────────────────────────────────────
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=your_google_api_key

# ─── Screenshots (Browserless.io) ─────────────────────────────────────────────
# https://www.browserless.io/
BROWSERLESS_API_KEY=your_browserless_key
BROWSERLESS_URL=https://chrome.browserless.io

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Brevo (emails) ───────────────────────────────────────────────────────────
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your_key
BREVO_TEMPLATE_ID=1
BREVO_FROM_EMAIL=rapports@velifa.io
BREVO_FROM_NAME=VELIFA

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# Numéro sans espaces ni + (ex: 33612345678)
WHATSAPP_NUMBER=33612345678

# ─── Sécurité ─────────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=your_turnstile_secret
JWT_SECRET=change_me_min_32_chars_random_string

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
# Laisser vide en dev, obligatoire en prod
SENTRY_DSN=

# ─── Lemon Squeezy (paiements) ────────────────────────────────────────────────
# https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_ls_api_key
# https://app.lemonsqueezy.com/stores → ID numérique du store
LEMONSQUEEZY_STORE_ID=12345
# ID de la variante du plan Pro (onglet Products → Variants)
LEMONSQUEEZY_PRO_VARIANT_ID=111111
# ID de la variante du plan Business
LEMONSQUEEZY_BUSINESS_VARIANT_ID=222222
# Clé secrète configurée dans Webhooks → Signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
